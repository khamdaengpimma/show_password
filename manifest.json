{
  "manifest_version": 3,
  "name": "Password Viewer Pro",
  "version": "3.0",
  "description": "Show/Hide password fields with eye button and popup control",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Password Viewer"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}